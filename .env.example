# URL publica do projeto no Vercel
PUBLIC_BASE_URL=https://seu-projeto.vercel.app

# Banco Supabase via Transaction Pooler (ideal para Vercel/serverless)
# Enquanto DB_DISABLED=true, o servidor usa os dados locais do codigo e nao conecta no Supabase.
DB_DISABLED=true
# Pegue no Supabase em Connect > Transaction pooler e troque [YOUR-PASSWORD]
# pela senha URL-encoded (ex.: @ vira %40).
SUPABASE_POOLER_URL=postgresql://postgres.[PROJECT_REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
DB_CONNECTION_LIMIT=1
DB_IDLE_TIMEOUT=10000


# SMTP Gmail para confirmacao de inscricao
EMAIL_USER=seu-email@gmail.com
EMAIL_PASS=sua-senha-de-app-do-gmail
EMAIL_FROM="Vix Cursos <seu-email@gmail.com>"
