{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "style.css",
      "use": "@vercel/static"
    },
    {
      "src": "manifest.webmanifest",
      "use": "@vercel/static"
    },
    {
      "src": "sw.js",
      "use": "@vercel/static"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "^/$",
      "dest": "/index.html"
    },
    {
      "src": "^/index\\.html$",
      "dest": "/index.html"
    },
    {
      "src": "^/style\\.css$",
      "dest": "/style.css"
    },
    {
      "src": "^/manifest\\.webmanifest$",
      "dest": "/manifest.webmanifest"
    },
    {
      "src": "^/sw\\.js$",
      "dest": "/sw.js"
    },
    {
      "src": "^/vocacional$",
      "dest": "/public/pages/vocacional.html"
    },
    {
      "src": "^/detalhes$",
      "dest": "/public/pages/detalhes.html"
    },
    {
      "src": "^/informacoes$",
      "dest": "/public/pages/informacoes.html"
    },
    {
      "src": "^/pre_inscricao$",
      "dest": "/public/pages/pre_inscricao.html"
    },
    {
      "src": "^/admin/(.*)$",
      "dest": "/public/admin/$1"
    },
    {
      "src": "^/css/(.*)$",
      "dest": "/public/css/$1"
    },
    {
      "src": "^/css_adm/(.*)$",
      "dest": "/public/admin/css_adm/$1"
    },
    {
      "src": "^/script/(.*)$",
      "dest": "/public/script/$1"
    },
    {
      "src": "^/components/(.*)$",
      "dest": "/public/components/$1"
    },
    {
      "src": "^/imagem/(.*)$",
      "dest": "/public/imagem/$1"
    },
    {
      "src": "^/pages/(.*)$",
      "dest": "/public/pages/$1"
    },
    {
      "src": "^/public/(.*)$",
      "dest": "/public/$1"
    },
    {
      "src": "^/favicon\\.ico$",
      "dest": "/public/favicon.png"
    },
    {
      "src": "^/favicon\\.png$",
      "dest": "/public/favicon.png"
    },
    {
      "src": "^/(api|cursos|inscricao|inscritos|chat)(?:/.*)?$",
      "dest": "/api/index.js"
    },
    {
      "src": "^/public/(curso|idade|categoria|modalidade|local)$",
      "dest": "/api/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
